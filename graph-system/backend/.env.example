NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-pass-graph-system

# Optional: override dataset location (defaults to workspaceRoot/sap-o2c-data)
# DATA_ROOT=../sap-o2c-data

PORT=4000

# LLM (free-tier friendly; used only to translate NL -> intent plan)
LLM_PROVIDER=openrouter   # openrouter | groq
LLM_API_KEY=YOUR_API_KEY
LLM_MODEL=meta-llama/llama-3.1-70b-instruct

